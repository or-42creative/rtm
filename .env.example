# Firebase web app config — copy this file to ".env" and fill from the
# Firebase console (Project settings > General > Your apps > Web app > SDK config).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Only Google accounts on this email domain may sign in (comma-separated for several).
VITE_ALLOWED_EMAIL_DOMAINS=42creative.co.il

# Emails that get the admin role automatically on first login (comma-separated).
# Put the first administrator here so they can manage everything + seed the data.
VITE_BOOTSTRAP_ADMIN_EMAILS=
